# App URL — local dashboard & default Twilio signature URL
NEXT_PUBLIC_APP_URL=http://localhost:3020

# Supabase (free tier): Project Settings → Database → connection string (Transaction pooler or Direct)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Kiwi Tequila — https://tequila.kiwi.com/portal/ (free search API)
TEQUILA_API_KEY=""

# Twilio — https://console.twilio.com/ (trial credits, then ~$0.0079/SMS)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# Must match the exact URL Twilio POSTs to (use your ngrok https URL + /api/sms when testing locally)
# TWILIO_WEBHOOK_URL="https://xxxx.ngrok-free.app/api/sms"

# Set to false only for local debugging when signature validation fails
TWILIO_VALIDATE_SIGNATURE="true"

# Vercel cron: Project → Settings → Environment Variables (generate a random string)
CRON_SECRET=""
