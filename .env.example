NEXT_PUBLIC_APP_URL=http://localhost:3020

# ── Database (Neon — neon.tech, free tier, never pauses) ──────────────────────
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ── Telegram (V1 personal bot) ────────────────────────────────────────────────
# Create bot: open Telegram → @BotFather → /newbot → copy token
TELEGRAM_BOT_TOKEN_V1="your-telegram-bot-token-here"
# Your personal chat ID: message @userinfobot on Telegram to get it
V1_USER_TELEGRAM_CHAT_ID="your-telegram-chat-id-here"

# ── Amadeus Flight Search (developer.amadeus.com — free tier) ─────────────────
AMADEUS_CLIENT_ID="your-amadeus-client-id"
AMADEUS_CLIENT_SECRET="your-amadeus-client-secret"

# ── Cron protection ───────────────────────────────────────────────────────────
CRON_SECRET="generate-a-random-secret-here"

# ── Legacy / optional ─────────────────────────────────────────────────────────
IGNAV_API_KEY=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
