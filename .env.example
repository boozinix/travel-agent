NEXT_PUBLIC_APP_URL=http://localhost:3020

# If db.*:6543 is blocked on your network, use Session pooler for BOTH (Connect → Session pooler).
DATABASE_URL="postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres.YOUR_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# Alternative when your network allows it: transaction pooler + direct (see Supabase Connect → Connection string)
# DATABASE_URL="postgresql://postgres:PASSWORD@db.YOUR_REF.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# DIRECT_URL="postgresql://postgres:PASSWORD@db.YOUR_REF.supabase.co:5432/postgres?sslmode=require"

# Ignav — https://ignav.com/signup (free 1000 requests, replaces Tequila which closed signups)
IGNAV_API_KEY=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
TWILIO_VALIDATE_SIGNATURE="true"
CRON_SECRET=""
