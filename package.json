{
  "name": "travel-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--dns-result-order=ipv4first next dev -p 3020",
    "build": "prisma generate && next build",
    "start": "NODE_OPTIONS=--dns-result-order=ipv4first next start -p 3020",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "NODE_OPTIONS=--dns-result-order=ipv4first prisma db push",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@ai-sdk/openai": "^0.0.40",
    "@prisma/client": "5.22.0",
    "@supabase/supabase-js": "^2.101.0",
    "ai": "^3.3.0",
    "next": "16.2.1",
    "prisma": "5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "twilio": "^5.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.4.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
